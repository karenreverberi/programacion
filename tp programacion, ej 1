<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Tarjeta Perfil</title>

    <style>
        body {
              display: flex;
              justify-content: center;
              align-items: center;
              height: 100vh;
              background-color: pink;
         } 
        #tarjeta {
                  background: white;
                  padding: 20px;
                  width: 300px;
                  text-align: center;
                  border-radius: 15px;
                  box-shadow: 0px 4px 10px rgba(0,0,0,0.2);
                  transition: transform 0.3s ease;
                  box-shadow: 0.3s ease;
        }
        #tarjeta:hover {
                        transform: translateY(-10px);
                        box-shadow: 0px 12px 25px rgba(0,0,0,0.3);
        }
        .foto {
               width: 100px;
               height: 100px;
               border-radius: 50%;
               object-fit: cover;
               margin-bottom: 10px;
        }
        .nombre {
                  font-size: 22px;
                  font-weight: bold;
                  margin: 10px;
        }

        .rol {
              color: gray;
              margin-bottom: 10px;
        }
        .descripcion {
                     font-size: 14px;
                     margin: 10px;
                     color: #555;
        }
        .estadisticas {
                       display: flex;
                       justify-content: space-around;
                       margin-top: 15px;
        }
    </style>
</head>
<body>
    <div id="tarjeta">
        <img src="https://via.placeholder.com/100" class="foto">

        <h2 class="nombre">Karen barraza</h2>
        <p class="rol">Programadora</p>
        <p class="descripcion">Me gusta aprender desarrollo web y mejorar mis habilidades.</p>

        <div class="estadisticas">
            <div>
                <p>1,1k</p>
                <span>Seguidores</span>
            </div>
            <div>
                <p>50</p>
                <span>Siguiendo</span>
            </div>
        </div>
    </div>

</body>
</html>